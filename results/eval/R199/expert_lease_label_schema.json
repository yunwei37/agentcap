{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "action_leases": {
      "items": {
        "properties": {
          "allowed_sinks": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "argument_constraints": {
            "type": "object"
          },
          "budget": {
            "type": "object"
          },
          "control_may_depend_on": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "control_must_not_depend_on": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "data_may_depend_on": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "delegation": {
            "type": "string"
          },
          "expiry": {
            "type": "string"
          },
          "object": {
            "type": "string"
          },
          "operation": {
            "type": "string"
          }
        },
        "required": [
          "operation",
          "object",
          "argument_constraints",
          "budget",
          "expiry"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "allowed_context_influence": {
      "items": {
        "properties": {
          "constraints": {
            "type": "string"
          },
          "decision_classes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "modes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "source": {
            "type": "string"
          }
        },
        "required": [
          "source",
          "modes",
          "decision_classes"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "type": "string"
    },
    "forbidden_authority": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "intent_certificate": {
      "additionalProperties": true,
      "required": [
        "goal",
        "trusted_sources",
        "objects",
        "sinks",
        "expiry"
      ],
      "type": "object"
    },
    "labeler_id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "sample_id": {
      "type": "string"
    }
  },
  "required": [
    "sample_id",
    "labeler_id",
    "intent_certificate",
    "allowed_context_influence",
    "action_leases",
    "forbidden_authority",
    "confidence"
  ],
  "title": "IntentCap expert oracle lease label",
  "type": "object"
}