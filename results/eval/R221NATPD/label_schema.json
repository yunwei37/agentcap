{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "decision_class": {
      "type": "string"
    },
    "is_protected_decision": {
      "type": "boolean"
    },
    "label_scope": {
      "type": "string"
    },
    "labeler": {
      "type": "string"
    },
    "needs_env_runtime_proof": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    },
    "observed_substitution_attempt": {
      "type": "boolean"
    },
    "owner_fields": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "required_issuers_human": {
      "items": {
        "enum": [
          "agent",
          "instruction",
          "tool",
          "env"
        ]
      },
      "type": "array",
      "uniqueItems": true
    },
    "sample_id": {
      "type": "string"
    },
    "unsafe_substitutes": {
      "items": {
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "sample_id",
    "is_protected_decision",
    "required_issuers_human",
    "owner_fields",
    "unsafe_substitutes",
    "needs_env_runtime_proof",
    "observed_substitution_attempt",
    "decision_class",
    "confidence",
    "labeler",
    "label_scope",
    "notes"
  ],
  "title": "IntentCap natural protected-decision label",
  "type": "object"
}